# CryptoForge Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Exchange API Keys (NEVER enable withdrawal permission)
CRYPTOFORGE_EXCHANGE__API_KEY=your_api_key_here
CRYPTOFORGE_EXCHANGE__API_SECRET=your_api_secret_here

# Telegram Bot
CRYPTOFORGE_TELEGRAM__BOT_TOKEN=your_telegram_bot_token
CRYPTOFORGE_TELEGRAM__CHAT_ID=your_telegram_chat_id

# Database (Docker service names — required for docker-compose)
DB_PASSWORD=change_this_to_a_strong_password
CRYPTOFORGE_DATABASE__TIMESCALEDB_URL=postgresql+asyncpg://bot:change_this_to_a_strong_password@timescaledb:5432/cryptoforge
CRYPTOFORGE_DATABASE__REDIS_URL=redis://redis:6379/0

# Grafana
GRAFANA_PASSWORD=admin

# Mode: paper | live | backtest
CRYPTOFORGE_TRADING__MODE=paper
